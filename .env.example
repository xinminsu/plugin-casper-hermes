# Casper Hermes Plugin — Environment Configuration
# Copy to ~/.hermes/.env or export in your shell

# RPC endpoint (default: Casper public testnet)
CASPER_NODE_URL=https://node.testnet.casper.network/rpc

# Optional: authenticated RPC bearer token
# CASPER_API_KEY=

# Chain name for deploys: casper-test (testnet) or casper (mainnet)
CASPER_CHAIN_NAME=casper-test

# Write operations (transfers, contract calls) also require Node.js:
# cd scripts && npm install

