# Casper Hermes Plugin — Environment Configuration
# Copy to ~/.hermes/.env or export in your shell

# Casper RPC (optional overrides)
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
# CASPER_RPC_TIMEOUT=45
# CASPER_RPC_RETRIES=2

# Chain/network: casper-test (testnet) or casper (mainnet)
# Tools also accept network=testnet|mainnet per call.
CASPER_CHAIN_NAME=casper-test

# Write operations (transfers, contract calls) also require Node.js:
# cd scripts && npm install

# Signing key for write operations (hex or PEM — set one, not both)
# CASPER_SIGNING_KEY_HEX=<64-char hex private key>
# CASPER_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# CASPER_KEY_ALGORITHM=ed25519
# CASPER_KEY_ALGORITHM=secp256k1
